# ============================================
# YouDub 配置文件
# 复制此文件为 .env 并填写配置
# ============================================

# --- 翻译服务 ---
# OpenAI API Key（必填，用于字幕翻译）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY = 

# OpenAI API Base URL（可选，默认为官方地址）
# 如使用代理或自部署模型，请修改此项
OPENAI_API_BASE = https://api.openai.com/v1

# 模型名称（可选，默认为 gpt-3.5-turbo）
MODEL_NAME = gpt-3.5-turbo

# --- 语音识别 ---
# HuggingFace Token（必填，用于说话者分离功能）
# 获取方式：https://huggingface.co/settings/tokens
HF_TOKEN = 

# HuggingFace 镜像地址（可选，用于国内加速下载模型）
# HF_ENDPOINT = https://hf-mirror.com

# --- 语音合成（火山引擎）---
# 火山引擎 TTS App ID（必填，用于语音合成）
# 获取方式：https://console.volcengine.com/
BYTEDANCE_APPID = 

# 火山引擎 TTS Access Token（必填，用于语音合成）
BYTEDANCE_ACCESS_TOKEN = 

# --- B站上传 ---
# B站 SESSDATA（上传视频需要，从浏览器 Cookie 中获取）
BILI_SESSDATA = 

# B站 bili_jct（上传视频需要，从浏览器 Cookie 中获取）
BILI_BILI_JCT = 

# B站视频封面 Base64（可选）
BILI_BASE64 = 
